{
  "name": "anasoko-dani-generator",
  "version": "0.1.0",
  "description": "Anasoko 段位道場セット ジェネレーター",
  "main": "./out/main/index.js",
  "author": "",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/switch-sqlite-abi.mjs electron",
    "rebuild:electron": "node scripts/switch-sqlite-abi.mjs electron",
    "rebuild:node": "node scripts/switch-sqlite-abi.mjs node",
    "predev": "npm run rebuild:electron",
    "dev": "electron-vite dev",
    "prebuild": "npm run rebuild:electron",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --ext .ts,.tsx",
    "pretest": "npm run rebuild:node",
    "test": "vitest run",
    "posttest": "npm run rebuild:electron"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "better-sqlite3": "^11.3.0",
    "iconv-lite": "^0.6.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yauzl": "^3.1.3",
    "yazl": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^2.4.5",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.15.0",
    "@typescript-eslint/parser": "^7.15.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.2.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vitest": "^1.6.0"
  },
  "allowScripts": {
    "electron@31.7.7": true,
    "esbuild@0.21.5": true,
    "better-sqlite3@11.10.0": true
  }
}
